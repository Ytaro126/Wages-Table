{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["DOM", "ES2020"],
    "rootDir": "src",
    "outDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
